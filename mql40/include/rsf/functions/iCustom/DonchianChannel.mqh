
#define Donchian.MODE_UPPER_BAND  0    // upper channel band
#define Donchian.MODE_LOWER_BAND  1    // lower channel band
#define Donchian.MODE_UPPER_CROSS 2    // upper channel band crossings
#define Donchian.MODE_LOWER_CROSS 3    // lower channel band crossings
#define Donchian.MODE_TREND       4    // int: direction and length of channel reversals
#define Donchian.MODE_REVERSALS   5    // int: number of consecutive winning/losing reversals
